DOM element is changed.\nAs can be seen from the re-performance from the layout stage, it is a costly task because not only the changed elements but also the calculation of other elements must be re-performed.\nTherefore, the browser collects tasks that require reflow in the queue to reduce this cost and schedules them for processing in one reflow in the next frame."}]},{"type":"element","tag":"p","props":{},"children":[{"type":"text","value":"However, when trying to process reading and writing geometric values in one frame, the reflow is performed immediately.\nThis is called "},{"type":"element","tag":"strong","props":{},"children":[{"type":"text","value":"forced synchronous layout"}]},{"type":"text","value":", and a phenomenon in which forced synchronous layout occurs repeatedly, resulting in performance degradation is called "},{"type":"element","tag":"strong","props":{},"children":[{"type":"text","value":"layout thrashing"}]},{"type":"text","value":"."}]},{"type":"element","tag":"h3","props":{"id":"prevent-layout-thrashing"},"children":[{"type":"text","value":"Prevent layout thrashing"}]},{"type":"element","tag":"p","props":{},"children":[{"type":"text","value":"The code mentioned above reads the geometric value of "},{"type":"element","tag":"code","props":{},"children":[{"type":"text","value":"top"}]},{"type":"text","value":", resulting in a forced synchronous layout.\nTherefore, we will use the features of "},{"type":"element","tag":"code","props":{},"children":[{"type":"text","value":"rAF()"}]},{"type":"text","value":" described above to separate the read logic that causes the reflow and hand over the remaining computational logic to "},{"type":"element","tag":"code","props":{},"children":[{"type":"text","value":"rAF()"}]},{"type":"text","value":" as a callback function.\nThis effectively defends layout thrashing because the "},{"type":"element","tag":"strong","props":{},"children":[{"type":"text","value":"read is processed in the current frame"}]},{"type":"text","value":", and the "},{"type":"element","tag":"strong","props":{},"children":[{"type":"text","value":"rest of the operations are collected in the next frame and processed in one time"}]},{"type":"text","value":"."}]},{"type":"element","tag":"pre","props":{"className":"language-js material-theme-lighter_material-theme-ocean","code":"function onScroll(height){\n  element.style.height = height * 2\n}\n\nwindow.addEventListener('scroll', () => {\n  const box = element.getBoundingClientRect();\n  if(box.top > pos){\n      requestAnimationFrame(()=>{\n          onScroll(box.height)\n      })\n  }\n});\n","language":"js","meta":""},"children":[{"type":"element","tag":"code","props":{"__ignoreMap":""},"children":[{"type":"element","tag":"span","props":{"class":"line","line":1},"children":[{"type":"element","tag":"span","props":{"class":"ct-953144"},"children":[{"type":"text","value":"function"}]},{"type":"element","tag":"span","props":{"class":"ct-359564"},"children":[{"type":"text","value":" "}]},{"type":"element","tag":"span","props":{"class":"ct-407733"},"children":[{"type":"text","value":"onScroll"}]},{"type":"element","tag":"span","props":{"class":"ct-083011"},"children":[{"type":"text","value":"("}]},{"type":"element","tag":"span","props":{"class":"ct-153270"},"children":[{"type":"text","value":"height"}]},{"type":"element","tag":"span","props":{"class":"ct-083011"},"children":[{"type":"text","value":"){\n"}]}]},{"type":"element","tag":"span","props":{"class":"line","line":2},"children":[{"type":"element","tag":"span","props":{"class":"ct-412413"},"children":[{"type":"text","value":"  "}]},{"type":"element","tag":"span","props":{"class":"ct-359564"},"children":[{"type":"text","value":"element"}]},{"type":"element","tag":"span","props":{"class":"ct-083011"},"children":[{"type":"text","value":"."}]},{"type":"element","tag":"span","props":{"class":"ct-359564"},"children":[{"type":"text","value":"style"}]},{"type":"element","tag":"span","props":{"class":"ct-083011"}